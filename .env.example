# Copie para .env na raiz do repositório e preencha (nunca commite .env).

# LLM — formato OpenAI (ex.: OpenAI, ou proxy compatível)
LLM_API_KEY=your_openai_or_compatible_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# Zep — memória em grafo (https://app.getzep.com/)
ZEP_API_KEY=your_zep_api_key_here

# Opcional: caminho do SQLite de índice de histórico (padrão: backend/instance/mirofish_history.sqlite)
# HISTORY_INDEX_DB_PATH=

# Cópia automática na pasta do projeto após cada GET /api/simulation/history
# Padrão: backups/history_index/ na raiz do repositório
# MIROFISH_PROJECT_BACKUP_DIR=
# MIROFISH_DISABLE_PROJECT_BACKUP=true
# MIROFISH_PROJECT_BACKUP_VERSIONED=true

# Cópia extra para pasta fora do repo (opcional)
# MIROFISH_EXTERNAL_BACKUP_DIR=
# MIROFISH_EXTERNAL_BACKUP_VERSIONED=true

# Opcional: outro LLM para aceleração — omita se não usar
# LLM_BOOST_API_KEY=
# LLM_BOOST_BASE_URL=
# LLM_BOOST_MODEL_NAME=
